# 32-Byte-Hex-Key fuer AES-256-GCM Verschluesselung der SMB-Passwoerter.
# Generieren:  openssl rand -hex 32
ENCRYPTION_KEY=

# Initial-Admin fuer das Webinterface (wird beim ersten Start angelegt)
INITIAL_ADMIN_USER=admin
INITIAL_ADMIN_PASSWORD=changeme

# Webinterface-Port (Host)
HOST_PORT=4000

# Session-Lebensdauer (Stunden)
SESSION_TTL_HOURS=12
