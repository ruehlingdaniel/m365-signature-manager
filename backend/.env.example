# Port for backend
PORT=4000

# SQLite DB path
DB_PATH=./data/signatures.db

# Encryption key for client_secret at rest (32 bytes hex; generate with: openssl rand -hex 32)
ENCRYPTION_KEY=

# Initial admin (only used on first start to seed admin_users)
INITIAL_ADMIN_USER=admin
INITIAL_ADMIN_PASSWORD=changeme

# Cookie/session
SESSION_TTL_HOURS=12

# Public base URL (used in add-in manifest URLs)
PUBLIC_BASE_URL=http://localhost:4000
